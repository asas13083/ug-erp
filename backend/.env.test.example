# ============ قاعدة بيانات تجريبية منفصلة تماماً عن قاعدة بياناتك الحقيقية ============
# لازم تعمل قاعدة بيانات جديدة فاضية بس لغرض الاختبارات (مايتلمسش فيها بياناتك الحقيقية خالص)
#   psql -U postgres -c "CREATE DATABASE ug_erp_test;"
# وبعدين تطبّق عليها الـmigrations:
#   npx prisma migrate deploy
# (تأكد إنك مسجّل DATABASE_URL بتاع القاعدة التجريبية وقت ما تشغّل الأمر ده، مش قاعدتك الحقيقية)
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/ug_erp_test"

JWT_SECRET="test-secret-key-not-for-production"
JWT_EXPIRES_IN="8h"
NODE_ENV="test"
FRONTEND_ORIGIN="http://localhost:5173"
