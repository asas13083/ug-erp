# ============ قاعدة البيانات ============
# استبدل بالبيانات الحقيقية بتاعة السيرفر السحابي أو جهازك المحلي
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/ug_erp"

# ============ السيرفر ============
PORT=4000
NODE_ENV=production

# ============ الأمان (JWT) ============
# غيّر القيمة دي لأي نص عشوائي طويل وسري قبل الرفع الفعلي
JWT_SECRET="change-this-to-a-long-random-secret-string"
JWT_EXPIRES_IN="8h"

# ============ إعدادات إرسال الإيميل (SMTP) ============
# لو بتستخدم Gmail: فعّل "App Passwords" من إعدادات الأمان في حسابك
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="UG Production House ERP <your-email@gmail.com>"

# لو ظهرلك خطأ "self-signed certificate in certificate chain" (بيحصل غالباً بسبب
# برامج حماية زي Kaspersky/Avast بتراقب الاتصال المشفر)، فعّل السطر ده مؤقتاً:
# SMTP_TLS_REJECT_UNAUTHORIZED=false

# كل دقيقة يفحص النظام طابور الإيميلات ويحاول يبعتها (بالمللي ثانية)
EMAIL_QUEUE_INTERVAL_MS=60000

# كل يوم مرة تشتغل نسخة احتياطية تلقائية (بالمللي ثانية)، ومسار برنامج pg_dump لو مش في الـ PATH
BACKUP_INTERVAL_MS=86400000
# لو pg_dump مش شغال من غير المسار الكامل، حط المسار هنا (مثال ويندوز):
# PG_DUMP_PATH="C:\Program Files\PostgreSQL\16\bin\pg_dump.exe"
# نفس الفكرة بالظبط لبرنامج psql — مستخدم في استرجاع النسخ الاحتياطية:
# PSQL_PATH="C:\Program Files\PostgreSQL\16\bin\psql.exe"

# ============ الرفع التلقائي للنسخ الاحتياطية على جوجل درايف (اختياري) ============
# اتبع دليل الإعداد (شغّل: node scripts/googleDriveSetup.js) عشان تجيب القيم دي
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GOOGLE_REFRESH_TOKEN=""
# فولدر معين جوه درايف ترفع فيه (اختياري — لو فاضي هيرفع في الجذر الرئيسي)
# GOOGLE_DRIVE_FOLDER_ID=""

# الساعة (بنظام 24 ساعة) اللي بيتبعت فيها التقرير اليومي بالإيميل — افتراضياً 22 (10 بالليل)
DAILY_REPORT_HOUR=22

# ============ CORS ============
# الرابط اللي هيفتح منه الفرونت إند (هيتغير بعد رفع النظام)
# مهم جداً: ده مش مجرد إعداد شكلي — النظام دلوقتي بيستخدم كوكيز آمنة (httpOnly)
# لجلسة الدخول، والمتصفح بيرفض أي طلب فيه كوكيز لو الرابط هنا مش مطابق
# بالظبط لرابط الفرونت إند الحقيقي. لازم يبقى الرابط الكامل الصحيح، مش *
FRONTEND_ORIGIN="http://localhost:5173"
